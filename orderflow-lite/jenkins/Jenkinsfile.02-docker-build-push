    }

    post {
        success {
            echo "Pushed ${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} (and :latest) — build #${env.BUILD_NUMBER}."
        }
        failure {
            echo "OrderFlow-Lite build #${env.BUILD_NUMBER} failed — check the stage logs above."
        }
    }
}
