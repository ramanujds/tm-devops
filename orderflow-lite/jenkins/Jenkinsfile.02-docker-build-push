// OrderFlow-Lite CI pipeline — stage 2 of the training buildup.
//
// Builds on Jenkinsfile.01-checkout-test-build-run: keeps Checkout and
// Test as-is, but replaces the no-Docker "Build"/"Run (locally)" stages
// with a real Docker image build and a push to a registry — this is the
// Module 4 (Docker Fundamentals and Image Security) tie-in. Image
// scanning (Trivy) is intentionally NOT in this file yet — that's the
// next numbered Jenkinsfile.
//
// Assumes a Jenkins agent with Docker available on PATH (Docker-in-Docker
// or a mounted host Docker socket) and the Docker Pipeline plugin
// installed (provides the `docker.withRegistry` / `docker.image()` DSL
// used below).
//
// REGISTRY / credentials: defaults to a local, unauthenticated registry
// (`localhost:5000`) — confirmed working end-to-end with Docker Desktop's
// built-in Kubernetes, which shares its Docker daemon with the registry
// container, so no extra "load the image into the cluster" step is
// needed. See content/local-registry-setup.md for the full manual setup
// and why kind/Minikube need that extra step and this doesn't. Point
// REGISTRY at a real registry (Docker Hub, ECR, ACR, etc.) and set
// DOCKER_CREDENTIALS_ID to a real Jenkins credentials ID to push
// somewhere durable — see the Docker Push stage for exactly what changes.

pipeline {
    agent any

    options {
        timestamps()
        timeout(time: 15, unit: 'MINUTES')
    }

    environment {
        IMAGE_NAME = 'orderflow-lite'
        IMAGE_TAG  = "${env.BUILD_NUMBER}"
        // Local, unauthenticated registry by default — see file header.
        // Docker's daemon.json needs this host listed under
        // "insecure-registries" unless you switch to a TLS-enabled one.
        REGISTRY = 'localhost:5000'
        // Only read if REGISTRY is switched to something that requires
        // auth (see Docker Push stage) — must match a Username/Password
        // credential configured in Jenkins (Manage Jenkins > Credentials).
        DOCKER_CREDENTIALS_ID = 'dockerhub-creds'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // stage('Test') {
