# Copy this file to .env and fill in real values for local development.
# Never commit an actual .env file.

# HTTP server
PORT=3000

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=orderflow
DB_PASSWORD=changeme
DB_NAME=orderflow

# Required on every request to /orders* routes via the x-api-key header
API_KEY=changeme-api-key

# How often (ms) the internal background worker polls for pending orders
WORKER_POLL_INTERVAL_MS=5000
